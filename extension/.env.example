# Squarelet OIDC public client credentials for the Klaxon extension.
#
# Register a public client (client_type=public, PKCE) in Squarelet admin and
# put the resulting client_id here. No client_secret — public clients don't use
# one. The extension's redirect URI must be registered with the client too;
# it's visible in the service worker console via chrome.identity.getRedirectURL().

MUCKROCK_ACCOUNTS_HOST="https://dev.squarelet.com/"
MUCKROCK_CLIENT_ID=""
MUCKROCK_SCOPES="openid profile email uuid organizations"

# DocumentCloud API base URL (with trailing slash)
MUCKROCK_DOCUMENTCLOUD_API="https://api.www.documentcloud.org/api/"
# Klaxon add-on ID in DocumentCloud
MUCKROCK_KLAXON_ID=""

{
  "name": "klaxon-browser-extension",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:content": "vite build --watch",
    "dev:service": "vite build --watch -c vite.config.background.ts",
    "build": "vite build && vite build -c vite.config.background.ts",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.3.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/chrome": "^0.1.40",
    "@types/node": "^22",
    "globals": "^17.3.0",
    "happy-dom": "^20.7.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.3.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
